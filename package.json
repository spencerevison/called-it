{
  "name": "called-it",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:db": "vitest run -c vitest.config.db.ts",
    "eval:smoke": "vitest run -c vitest.config.smoke.ts",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "db:types": "supabase gen types typescript --local > src/lib/supabase/types.ts",
    "db:seed": "node scripts/seed.mjs",
    "db:register-prompts": "node scripts/register-prompts.mjs",
    "eval:import": "node scripts/eval-import.mjs",
    "eval:judge": "node --import ./scripts/ts-alias-loader.mjs scripts/eval-judge.mjs",
    "eval:premortem": "node --import ./scripts/ts-alias-loader.mjs scripts/eval-premortem.mjs",
    "eval:compare": "node --import ./scripts/ts-alias-loader.mjs scripts/eval-compare.mjs",
    "eval:contamination": "node --import ./scripts/ts-alias-loader.mjs scripts/eval-contamination.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "@trigger.dev/sdk": "^4.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "langfuse": "^3.38.20",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "radix-ui": "^1.6.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.17.1",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "supabase": "^2.109.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
