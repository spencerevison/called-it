# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — pre-mortem generation + judge (live calls gated on this being set;
# tests always mock the LLM)
ANTHROPIC_API_KEY=

# Trigger.dev — durable check-in scheduling (F4)
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_ID=

# Langfuse — tracing for premortem/judge calls, tagged by prompt_version
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Judge scores show an "experimental" badge on the decision page until this is
# flipped to "true" — do that once eval:judge clears the EVAL_PLAN.md §4 bar
JUDGE_TRUSTED=

# Resend — due check-in email notifications (unset = feature no-ops)
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@called-it.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
